# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Visor Coordinator Agent — Environment Variables                             ║
# ║                                                                            ║
# ║  SCOPE:                                                                    ║
# ║  ──────                                                                    ║
# ║  This file is ONLY for the Express coordinator agent (agent/).             ║
# ║  The root .env handles the Next.js UI (NEXT_PUBLIC_* variables).           ║
# ║  They are independent — different processes, different env files.           ║
# ║                                                                            ║
# ║  SETUP:                                                                    ║
# ║  ──────                                                                    ║
# ║  1. Copy this file:   cp .env.example .env                                 ║
# ║  2. The defaults below work out of the box for the demo.                   ║
# ║  3. NEVER commit the active .env file — it is gitignored.                  ║
# ║                                                                            ║
# ║  HOW IT LOADS:                                                             ║
# ║  ─────────────                                                             ║
# ║  dotenv.config() in agent/src/index.ts:18 reads .env relative to cwd.     ║
# ║  Run with: cd agent && npm run dev                                         ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Server Configuration                                                       │
# └──────────────────────────────────────────────────────────────────────────────┘

# Port the Express coordinator agent listens on.
# Read by: agent/src/index.ts:21 (falls back to 3000)
PORT=3000


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Identity (Tenant DID)                                                       │
# └──────────────────────────────────────────────────────────────────────────────┘

# Tenant DID used as the calling-user identity in the WASM enclave context.
# ⚠️  Keep as did:t3n:maria123 for local demo — this matches the seeded
#    profile in data/fixtures/profiles.json and the hardcoded lookup in
#    agent/src/wasm-loader.ts:89. Changing it will break the demo flow.
# Read by: agent/src/index.ts:132 (falls back to did:t3n:maria123)
DID=did:t3n:maria123
